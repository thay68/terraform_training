}

# module.environment.aws_iam_role_policy.s3_access:
resource "aws_iam_role_policy" "s3_access" {
    id          = "myproject-prod-app-role:myproject-prod-s3-access"
    name        = "myproject-prod-s3-access"
    name_prefix = null
    policy      = jsonencode(
        {
            Statement = [
                {
                    Action   = [
                        "s3:GetObject",
                        "s3:ListBucket",
                    ]
                    Effect   = "Allow"
                    Resource = [
                        "arn:aws:s3:::myproject-prod-*",
                        "arn:aws:s3:::myproject-prod-*/*",
                    ]
                },
            ]
            Version   = "2012-10-17"
        }
    )
    role        = "myproject-prod-app-role"
}

