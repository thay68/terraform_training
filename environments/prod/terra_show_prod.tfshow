# module.environment.aws_iam_role.app:
resource "aws_iam_role" "app" {
    arn                   = "arn:aws:iam::566307772614:role/myproject-prod-app-role"
    assume_role_policy    = jsonencode(
        {
            Statement = [
                {
                    Action    = "sts:AssumeRole"
                    Effect    = "Allow"
                    Principal = {
                        Service = "ec2.amazonaws.com"
                    }
                },
            ]
            Version   = "2012-10-17"
        }
    )
    create_date           = "2026-07-21T21:41:02Z"
    description           = "Role for prod app servers"
    force_detach_policies = false
    id                    = "myproject-prod-app-role"
    managed_policy_arns   = []
    max_session_duration  = 3600
    name                  = "myproject-prod-app-role"
    name_prefix           = null
    path                  = "/"
    permissions_boundary  = null
    tags                  = {
        "BackupEnabled" = "true"
        "Compliance"    = "required"
        "CostCenter"    = "engineering-prod"
        "Environment"   = "prod"
        "ManagedBy"     = "terraform"
        "Project"       = "myproject"
    }
    tags_all              = {
        "BackupEnabled" = "true"
        "Compliance"    = "required"
        "CostCenter"    = "engineering-prod"
        "Environment"   = "prod"
        "ManagedBy"     = "terraform"
